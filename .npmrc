# Resolve the @troop10rwc scope from GitHub Packages. The packages are PUBLIC,
# but GH Packages' npm registry has no anonymous access, so a token is always
# required — even to install. See troop10rwc/kit consumer.npmrc.example.
#   - CI:        NPM_TOKEN: ${{ secrets.GITHUB_TOKEN }}
#   - Local dev: any classic PAT exported as NPM_TOKEN (or in your user ~/.npmrc).
@troop10rwc:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${NPM_TOKEN}
