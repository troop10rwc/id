{
  "name": "@troop10rwc/id",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "description": "Troop 10 RWC member identity hub — Slack-enrollment + passkey auth, D1 session issuance, profile/devices. Deploys independently to the apex (troop10rwc.org).",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "build": "vite build",
    "dev": "vite build && wrangler dev",
    "deploy": "vite build && wrangler deploy",
    "build:dashboard": "vite build --config vite.dashboard.config.ts",
    "dev:dashboard": "vite build --config vite.dashboard.config.ts && wrangler dev --config src/dashboard/wrangler.jsonc",
    "deploy:dashboard": "vite build --config vite.dashboard.config.ts && wrangler deploy --config src/dashboard/wrangler.jsonc",
    "typecheck": "tsc -p tsconfig.worker.json --noEmit && tsc -p tsconfig.client.json --noEmit",
    "test": "vitest run",
    "migrate:local": "wrangler d1 migrations apply troop10-id --local",
    "migrate:remote": "wrangler d1 migrations apply troop10-id --remote"
  },
  "dependencies": {
    "@simplewebauthn/browser": "^13.1.0",
    "@simplewebauthn/server": "^13.1.1",
    "@troop10rwc/shared": "^0.9.0",
    "@troop10rwc/ui": "^0.9.0",
    "@troop10rwc/worker-kit": "^0.9.0",
    "hono": "^4.6.0",
    "jose": "^5.9.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240000.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.6.0",
    "vite": "^6.4.2",
    "vitest": "^3.2.6",
    "wrangler": "^4.0.0"
  }
}
